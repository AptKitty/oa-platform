<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
 日程任务 Mapper XML
 对应 DAO: com.oa.schedule.dao.ScheduleDao
 负责日历事件(sch_calendar_event)、会议(sch_meeting)、会议参与人(sch_meeting_participant)、任务(sch_task)
 成员4 负责
-->
<mapper namespace="com.oa.schedule.dao.ScheduleDao">

    <!-- ==================== 日历事件 CalendarEvent ==================== -->
    <resultMap id="CalendarEventMap" type="com.oa.schedule.entity.CalendarEvent">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="event_type" property="eventType"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertEvent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sch_calendar_event(user_id, title, description, start_time, end_time, event_type)
        VALUES(#{userId}, #{title}, #{description}, #{startTime}, #{endTime}, #{eventType})
    </insert>

    <update id="updateEvent">
        UPDATE sch_calendar_event
        SET title=#{title}, description=#{description},
            start_time=#{startTime}, end_time=#{endTime}, event_type=#{eventType}
        WHERE id=#{id}
    </update>

    <delete id="deleteEvent">
        DELETE FROM sch_calendar_event WHERE id=#{id}
    </delete>

    <select id="findEventById" resultMap="CalendarEventMap">
        SELECT * FROM sch_calendar_event WHERE id=#{id}
    </select>

    <select id="findEventsByUser" resultMap="CalendarEventMap">
        SELECT * FROM sch_calendar_event
        WHERE user_id = #{userId}
        <if test="start != null and end != null">
            AND start_time &lt;= #{end} AND end_time &gt;= #{start}
        </if>
        ORDER BY start_time
    </select>

    <!-- ==================== 会议 Meeting ==================== -->
    <resultMap id="MeetingMap" type="com.oa.schedule.entity.Meeting">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="room_id" property="roomId"/>
        <result column="host_id" property="hostId"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insertMeeting" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sch_meeting(title, room_id, host_id, start_time, end_time, description, status)
        VALUES(#{title}, #{roomId}, #{hostId}, #{startTime}, #{endTime}, #{description}, #{status})
    </insert>

    <insert id="insertMeetingParticipant">
        INSERT INTO sch_meeting_participant(meeting_id, user_id)
        VALUES(#{meetingId}, #{userId})
    </insert>

    <select id="findMeetingsByTime" resultMap="MeetingMap">
        SELECT * FROM sch_meeting
        WHERE start_time &lt;= #{end} AND end_time &gt;= #{start}
        ORDER BY start_time
    </select>

    <!-- ==================== 任务 Task ==================== -->
    <resultMap id="TaskMap" type="com.oa.schedule.entity.Task">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="assigner_id" property="assignerId"/>
        <result column="assignee_id" property="assigneeId"/>
        <result column="due_date" property="dueDate"/>
        <result column="priority" property="priority"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertTask" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sch_task(title, description, assigner_id, assignee_id, due_date, priority, status)
        VALUES(#{title}, #{description}, #{assignerId}, #{assigneeId}, #{dueDate}, #{priority}, #{status})
    </insert>

    <update id="updateTaskStatus">
        UPDATE sch_task SET status=#{status} WHERE id=#{id}
    </update>

    <update id="updateTask">
        UPDATE sch_task
        SET title=#{title}, description=#{description},
            assignee_id=#{assigneeId}, due_date=#{dueDate},
            priority=#{priority}, status=#{status}
        WHERE id=#{id}
    </update>

    <select id="findTasksByAssignee" resultMap="TaskMap">
        SELECT * FROM sch_task
        WHERE assignee_id = #{assigneeId}
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY due_date
    </select>

</mapper>